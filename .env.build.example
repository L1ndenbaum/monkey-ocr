# Build-time configuration for deploy_ocr.sh. Copy to .env.build, or edit this
# file directly if you want the deploy script fallback to use these defaults.
#
# If your proxy listens on the host at 127.0.0.1:7890, keep that address here.
# deploy_ocr.sh rewrites 127.0.0.1/localhost to host.docker.internal for
# docker build and adds: --add-host=host.docker.internal:host-gateway

# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1,::1
no_proxy=localhost,127.0.0.1,::1

# Python package index used during docker build.
PIP_INDEX_URL=https://mirrors.ivolces.com/pypi/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=mirrors.ivolces.com

# Ubuntu APT mirrors used during docker build. If apt reports hash/file-size
# mismatch through a proxy, either retry later, clear/replace the proxy node,
# or switch these to a mirror that is healthy from your server.
APT_MIRROR=http://archive.ubuntu.com/ubuntu
APT_SECURITY_MIRROR=http://security.ubuntu.com/ubuntu
# Example alternatives:
# APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu
# APT_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu
APT_RETRIES=5
