# Build-time configuration for deploy_ocr.sh. Copy to .env.build, or edit this
# file directly if you want the deploy script fallback to use these defaults.
#
# If your proxy listens on the host at 127.0.0.1:7890, keep that address here.
# deploy_ocr.sh rewrites 127.0.0.1/localhost to host.docker.internal for
# docker build and adds: --add-host=host.docker.internal:host-gateway

# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1,::1
no_proxy=localhost,127.0.0.1,::1

# Python package index used during docker build.
PIP_INDEX_URL=https://mirrors.ivolces.com/pypi/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=mirrors.ivolces.com
