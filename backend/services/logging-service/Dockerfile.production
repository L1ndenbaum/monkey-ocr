FROM golang:1.22-alpine AS builder

WORKDIR /src

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG no_proxy
ARG GOPROXY=https://proxy.golang.org,direct
ARG GOSUMDB=sum.golang.org
ARG GONOPROXY
ARG GONOSUMDB

ENV GOPROXY=${GOPROXY} \
    GOSUMDB=${GOSUMDB} \
    GONOPROXY=${GONOPROXY} \
    GONOSUMDB=${GONOSUMDB}

COPY lib-go/go.mod lib-go/go.sum ./lib-go/
COPY logging-service/go.mod logging-service/go.sum ./logging-service/
WORKDIR /src/logging-service
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download
WORKDIR /src
COPY lib-go ./lib-go
COPY logging-service ./logging-service
WORKDIR /src/logging-service
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
	CGO_ENABLED=0 GOOS=linux go build -o /out/monkeyocr-logging-service ./cmd
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
	CGO_ENABLED=0 GOOS=linux go build -o /out/monkeyocr-clickhouse-writer ./cmd/clickhouse-writer

FROM alpine:3.20
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG no_proxy

RUN apk add --no-cache su-exec \
    && adduser -D -H -u 10001 appuser \
    && mkdir -p /var/lib/logging-service/spool /var/lib/logging-service/archive \
    && chown -R appuser:appuser /var/lib/logging-service
COPY logging-service/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
COPY --from=builder /out/monkeyocr-logging-service /usr/local/bin/monkeyocr-logging-service
COPY --from=builder /out/monkeyocr-clickhouse-writer /usr/local/bin/monkeyocr-clickhouse-writer
EXPOSE 13004
ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["monkeyocr-logging-service"]
