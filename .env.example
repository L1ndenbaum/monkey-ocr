# Runtime configuration for OCR Backend. Copy to .env and edit for deployment.

# Flask server
FLASK_ENV=production
HOST=0.0.0.0
PORT=7860
SECRET_KEY=change-me
LOG_LEVEL=INFO

# Container paths used by deploy_ocr.sh volume mounts
UPLOAD_FOLDER=/app/uploads
PROCESSED_FOLDER=/app/processed
MAX_CONTENT_LENGTH=104857600

# Image OCR legacy Gemini/Yunwu path. Leave empty if image OCR is not used or is routed elsewhere.
YUNWU_API_KEY=
YUNWU_API_BASE_URL=https://yunwu.ai/v1
DEFAULT_GEMINI_MODEL=gemini-2.0-flash-exp

# Scanned PDF OCR downstream service. This service calls the URL below for scanned PDF chunks.
MONKEY_OCR_API_URL=http://115.190.121.59:7860/api/process-base64
SCANNED_PDF_OCR_API_URL=http://115.190.121.59:7860/api/process-base64
SCANNED_PDF_CHUNK_SIZE=50
SCANNED_PDF_API_TIMEOUT=300
SCANNED_PDF_REQUEST_DELAY=0

# Docling options
DOCLING_TABLEFORMER_MODE=fast
SAVE_INTERMEDIATE_FILES=false
CLEANUP_TEMP_FILES=true
